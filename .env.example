# Finnhub API key — required for forex/index fallback data
FINNHUB_API_KEY=

# Anthropic API key — required for AI analysis pipeline
ANTHROPIC_API_KEY=

# Analysis cache TTL in seconds (default: 14400 = 4 hours)
ANALYSIS_CACHE_TTL=14400

# Claude model to use for analysis (default: claude-sonnet-4-5)
ANALYSIS_MODEL=claude-sonnet-4-5
